# --- Public URLs (two-surface deploy) -----------------------------------
# Authenticated app surface. Used by:
#   - safeOrigin() fallback when the request hostname is unroutable
#   - landing CTAs that link to /register and /login on the app domain
#   - middleware host-based routing
# Production: https://app.monivo.lt
# Local dev:  leave empty to keep everything on a single origin
NEXT_PUBLIC_SITE_URL="https://app.monivo.lt"

# Marketing surface. Used by metadata (OG), sitemap, robots, and middleware
# host-based routing so the app subdomain bounces legal/contact pages back
# to the landing domain.
# Production: https://monivo.lt
NEXT_PUBLIC_MARKETING_URL="https://monivo.lt"

# --- Supabase — required ------------------------------------------------
#
# Hosted project: use the supabase.co URL Supabase gave you.
# Local Supabase (supabase start): the default is http://127.0.0.1:54321,
# which works only from the same machine the dev server runs on.
# To test the app from a phone or another device on your LAN, set this to
# your computer's LAN IP, e.g. http://192.168.1.42:54321 — otherwise the
# phone's browser tries to reach 127.0.0.1 (itself) and the auth request
# fails with "Load failed" / network error before Supabase ever sees it.
# NEXT_PUBLIC_* values are inlined at build/start, so restart `next dev`
# after changing this.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-or-anon-key"

# Server-only. Required by the Stripe webhook handler to upsert profile rows
# while bypassing RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Resend — required for landing contact forms ------------------------
RESEND_API_KEY="re_..."
CONTACT_EMAIL="labas@monivo.lt"
# Optional override for the From: address (defaults to onboarding@resend.dev)
# CONTACT_FROM="Monivo <hello@monivo.lt>"

# --- Stripe — paused for now, configure when launching billing -----------
# Use test keys in preview, live keys only on production.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."
