# Supabase — required
#
# Hosted project: use the supabase.co URL Supabase gave you.
# Local Supabase (supabase start): the default is http://127.0.0.1:54321,
# which works only from the same machine the dev server runs on.
# To test the app from a phone or another device on your LAN, set this to
# your computer's LAN IP, e.g. http://192.168.1.42:54321 — otherwise the
# phone's browser tries to reach 127.0.0.1 (itself) and the auth request
# fails with "Load failed" / network error before Supabase ever sees it.
# NEXT_PUBLIC_* values are inlined at build/start, so restart `next dev`
# after changing this.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-or-anon-key"

# Resend — required for landing contact forms
RESEND_API_KEY="re_..."
CONTACT_EMAIL="hello@monivo.lt"
# Optional override for the From: address (defaults to onboarding@resend.dev)
# CONTACT_FROM="Monivo <hello@monivo.lt>"
